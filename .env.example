# IBKR Gateway connection
IB_HOST=ibgateway
IB_PORT=4002
IB_CLIENT_ID=7

# IBKR Gateway autologin (used by the ibgateway sibling container, not the bot itself)
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password
TRADING_MODE=paper

# Strategy
SYMBOLS=SPX
MAX_LOSS_USD=200
POP_THRESHOLD=0.70
RISK_FREE_RATE=0.05
ENTRY_TIME_ET=10:30
STOP_ENABLED=true
STOP_LATEST_SEC=30
# Optional: minimum max-loss-to-max-profit ratio of the spread.
# Set to e.g. "10" to require deep-ITM spreads where max_loss is at least
# 10x max_profit (high win-rate, low payoff). Leave unset for no constraint.
# MIN_LOSS_PROFIT_RATIO=10

# Persistence
STATE_DIR=./state

# Logging
LOG_LEVEL=INFO
