# Local dev .env example. The deployed bot reads its config from SSM
# (/<env>/ibkr-bull-call/settings JSON) — the env vars here override the
# Settings dataclass defaults when SSM_PREFIX is unset.
#
# Each key maps 1:1 to a Settings field in src/bull_call/config.py.
# Defaults shown here match the dataclass defaults; only MAX_LOSS_USD
# is required.


# ---------- IBKR Client Portal Gateway connection -----------------
# The bot speaks to a locally-running gateway (managed by IBeam in
# production, or run manually for local dev). Defaults assume the
# IBeam Docker container is reachable as `ibgateway`.
IB_HOST=ibgateway
IB_PORT=4002
IB_CLIENT_ID=7


# ---------- IBKR account credentials (used by IBeam, NOT by the bot)
# Local dev only — IBeam picks these up to drive the Selenium login.
# In production these are SSM SecureStrings; the bot never touches
# them and they are not present on disk on the EC2 instance.
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password
TRADING_MODE=paper


# ---------- Strategy ----------------------------------------------
SYMBOLS=SPX
MAX_LOSS_USD=200             # required; > 0
POP_THRESHOLD=0.55           # in [0, 1]; 0.70 is unreachable for SPX 0DTE under normal IV
RISK_FREE_RATE=0.05
ENTRY_TIME_ET=10:30
ENTRY_DEADLINE_ET=13:00      # must be strictly > ENTRY_TIME_ET
ENTRY_TIMEOUT_SEC=300        # > 0; total per-attempt budget, split 50/50 across initial price + reprice
LEG_FILL_TIMEOUT_SEC=30      # > 0; post-fill leg-balance verification window
STOP_ENABLED=true
STOP_LATEST_SEC=30           # >= 0; suppress stop in the last N seconds before close

# Optional: minimum max-profit / max-loss ratio.
# 0.10 = at least $100 of profit per $1000 of risk. Caps both
# selection and the reprice ceiling. Set blank / unset for "no constraint".
# MIN_PROFIT_TO_LOSS_RATIO=0.10


# ---------- Operational safety (added in PRs #3-14) ----------------
# See README's "Operational safety" table for what each guards against.

# Monthly net-negative capital gate (R9). If MTD realized PnL turns
# negative, skip new entries for the rest of the month. Existing
# positions still managed.
MONTHLY_STOP_ON_NEGATIVE_PNL=true

# Skip new entries on NYSE half-days (early 1 pm ET close).
SKIP_HALF_DAYS=true

# R23a data-outage emergency flatten: silence sentinel cadence,
# reconnect attempts, total blind window before MKT-flatten.
# MONITORING_QUOTE_MAX_BLIND_SEC must be >= MONITORING_QUOTE_GRACE_SEC.
MONITORING_QUOTE_GRACE_SEC=15
MONITORING_RECONNECT_MAX_ATTEMPTS=3
MONITORING_QUOTE_MAX_BLIND_SEC=60

# Liveness signal: cadence at which a background thread emits a
# "heartbeat" event (CloudWatch can alarm on absence).
HEARTBEAT_INTERVAL_SEC=300

# Session-level crash recovery: backoff between attempts and the
# circuit-breaker threshold (after N consecutive errors, exit so ASG
# respawns with fresh state).
SESSION_ERROR_BACKOFF_SEC=300
SESSION_ERROR_MAX_CONSECUTIVE=5


# ---------- Storage / logging --------------------------------------
# DynamoDB table holding spread records + stop journal + monthly P&L.
# Set by CloudFormation on EC2 deploys via systemd EnvironmentFile.
STATE_TABLE=bull-call-dev-state

LOG_LEVEL=INFO
