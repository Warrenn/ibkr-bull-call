# IBKR Gateway connection
IB_HOST=ibgateway
IB_PORT=4002
IB_CLIENT_ID=7

# IBKR Gateway autologin (used by the ibgateway sibling container, not the bot itself)
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password
TRADING_MODE=paper

# Strategy
SYMBOLS=SPX
MAX_LOSS_USD=200
POP_THRESHOLD=0.70
RISK_FREE_RATE=0.05
ENTRY_TIME_ET=10:30
STOP_ENABLED=true
STOP_LATEST_SEC=30
# Total seconds the entry limit order is allowed to work before we cancel
# and walk away. Split 50/50 across the initial price and one-tick reprice.
ENTRY_TIMEOUT_SEC=300

# ET clock time after which we stop retrying to enter today (no fill, no
# viable spread, repeated cancels — give up). Default 13:00 leaves ~3
# hours of session for a filled spread to work toward 4 pm settlement.
ENTRY_DEADLINE_ET=13:00

# After a combo fill, max seconds we wait for both legs to actually appear
# in positions before treating it as a leg-out and flattening the orphan
# leg at MKT.
LEG_FILL_TIMEOUT_SEC=30

# Optional: minimum max-profit-to-max-loss ratio of the spread.
# Set to e.g. "0.10" to require at least $0.10 of possible profit for every
# $1.00 of possible loss (i.e. for every $1000 of loss, at least $100 of
# profit). 0.20 = at least $200 profit per $1000 risked (more conservative).
# Enforced both at strike-selection AND on the limit-order reprice ceiling
# so a fill never delivers less profit margin than configured.
# MIN_PROFIT_TO_LOSS_RATIO=0.10

# Persistence
STATE_DIR=./state

# Logging
LOG_LEVEL=INFO
